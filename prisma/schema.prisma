generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String
  createdAt DateTime  @default(now())
  clientes  Cliente[]

  @@map("users")
}

model Cliente {
  id        String    @id @default(cuid())
  nome      String
  telefone  String
  email     String
  createdAt DateTime  @default(now())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  veiculos  Veiculo[]

  @@unique([email, userId])
  @@index([userId])
  @@map("clientes")
}

enum VeiculoTipo {
  Sedan
  Hatch
  SUV
  Picape
  Esportivo
  Moto
  Outro
}

model Veiculo {
  id        String      @id @default(cuid())
  placa     String
  marca     String
  modelo    String
  cor       String?     // Hex color (#RRGGBB) ou nome textual fallback
  tipo      VeiculoTipo @default(Outro)
  fotoUrl   String?     // URL da foto enviada pelo usuário (Vercel Blob)
  createdAt DateTime    @default(now())
  clienteId String
  cliente   Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  ordens    Ordem[]

  @@unique([placa, clienteId])
  @@index([clienteId])
  @@map("veiculos")
}

enum OrdemStatus {
  Aberta
  EmAndamento
  Concluida
  Cancelada
}

model Ordem {
  id        String      @id @default(cuid())
  descricao String
  valor     Decimal     @db.Decimal(10, 2)
  status    OrdemStatus @default(Aberta)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  veiculoId String
  veiculo   Veiculo     @relation(fields: [veiculoId], references: [id], onDelete: Cascade)

  @@index([veiculoId])
  @@map("ordens")
}
