# Banco PostgreSQL usado pelo Prisma
# Exemplos: Neon, Supabase, Railway ou Postgres local.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Segredo usado para assinar JWTs.
# Em produção, use um valor longo e aleatório:
# openssl rand -base64 32
JWT_SECRET="troque-por-um-segredo-longo-e-aleatorio"

# Token do Vercel Blob para upload/remover fotos de veículos.
# Necessário para POST/DELETE /api/veiculos/:id/foto.
BLOB_READ_WRITE_TOKEN=""
